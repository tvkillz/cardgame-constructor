# Admin API creds for upload / migrate scripts on the frontend VPS.
# Copy to .env.admin (gitignored) — not used by Next.js at runtime.
#
#   cp .env.admin.example .env.admin
#
# SERVICE_ROLE_KEY: copy from backend VPS backend/.env (never commit .env.admin)

NEXT_PUBLIC_SUPABASE_URL=https://api.voidborn.fun
SUPABASE_PUBLIC_URL=https://api.voidborn.fun
SERVICE_ROLE_KEY=
