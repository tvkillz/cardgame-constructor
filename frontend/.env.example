# Dev:  .env.development  (used by `npm run dev` / pm2 `dev`)
# Prod: .env.production   (used by `next build` / `next start`)
# Override either with .env.local (gitignored).
# VPS template: deploy/env.production.example

# Platform backend API (Supabase/Kong) — same for every site; NOT the public site domain.
# Example production value: https://voidborn.fun
NEXT_PUBLIC_SUPABASE_URL=https://api.your-platform.com
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy anon JWT (from voidborn-backend/docker/.env ANON_KEY)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local Supabase stack (Kong on port 8000):
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# localhost pm2: auth/rest/functions are proxied via Next (/auth/v1 → API).
# No CORS change needed; restart dev server after pulling updates.

# Card compile upload (npm run compile:upload) also reads backend/.env
# for SERVICE_ROLE_KEY — do not put the service role in frontend env files.

# Active content pack (default: voidborn). See projects/
# PROJECT=voidborn
