{
  "name": "voidborn-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:host": "HOSTNAME=0.0.0.0 node scripts/dev.mjs",
    "dev:next": "next dev",
    "dev:clean": "rm -rf .next && node scripts/dev.mjs",
    "build": "node scripts/build-prod.mjs",
    "build:game": "node scripts/build-game.mjs",
    "build:web": "node scripts/build-web.mjs",
    "build:next": "next build",
    "start": "next start",
    "start:prod": "node scripts/start-prod.mjs",
    "build:site": "node scripts/build-prod.mjs",
    "build:cpanel": "node scripts/build-cpanel.mjs",
    "upload:cpanel": "node scripts/upload-cpanel.mjs",
    "deploy:cpanel": "node scripts/build-cpanel.mjs --upload",
    "lint": "eslint .",
    "compile": "node scripts/compile-project.mjs",
    "compile:all": "node scripts/compile-all.mjs",
    "deploy:nginx": "node deploy/scripts/generate-nginx.mjs",
    "compile:watch": "node scripts/compile-watch.mjs",
    "compile:upload": "node scripts/compile-project.mjs --upload",
    "metadata:split": "node scripts/split-metadata.mjs --all",
    "upload:site": "node scripts/upload-site.mjs",
    "upload:all": "node scripts/upload-all.mjs",
    "migrate:auth-emails": "node --experimental-strip-types scripts/migrate-auth-emails.mjs",
    "site:list": "node ../projects/scripts/site-list.mjs",
    "site:url": "node ../projects/scripts/site-url.mjs",
    "site:add": "node ../projects/scripts/site-add.mjs",
    "site:sync": "node ../projects/scripts/site-sync-hints.mjs",
    "seed:cards": "node scripts/seed-cards.mjs",
    "seed:cards:upload": "node scripts/seed-cards.mjs --upload"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "@pixi/particle-emitter": "^5.0.10",
    "@pixi/react": "^8.0.5",
    "gsap": "^3.15.0",
    "next": "^15.5.4",
    "pixi.js": "^8.18.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~5.9.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.1",
    "sharp": "^0.34.5"
  }
}
