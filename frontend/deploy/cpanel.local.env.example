# Copy to cpanel.local.env (gitignored) — cPanel FTP sync for production (voidborn.fun).

# Server hostname from cPanel → Configure FTP Client (e.g. ftp.voidborn.fun)
CPANEL_FTP_HOST=ftp.voidborn.fun
CPANEL_FTP_USER=sync@voidborn.fun
CPANEL_FTP_PASS=

# Legacy Node deploy only — if account were jailed to voidborn-cpanel/
CPANEL_FTP_REMOTE_DIR=.

# Static deploy — account root is public_html → use .
CPANEL_STATIC_FTP_REMOTE_DIR=.

# plain | explicit | implicit — many cPanel hosts need plain FTP (0)
CPANEL_FTP_TLS=0
CPANEL_FTP_PORT=21

# Only for explicit/implicit TLS when cert hostname differs
CPANEL_FTP_TLS_SKIP_VERIFY=1
