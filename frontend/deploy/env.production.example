# Platform API URL (backend VPS) — NOT the public site domain (voidborn.fun).
NEXT_PUBLIC_SUPABASE_URL=https://api.voidborn.fun
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy HS256 anon JWT — fallback if publishable key is unavailable
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Staging gate — nginx basic auth on staging.* vhosts only (see deploy/nginx/site.conf.tpl).
# pm2 prod sets SITE_AUTH_DISABLED=1 on the VPS.
SITE_AUTH_USERNAME=dev
SITE_AUTH_PASSWORD=dev
