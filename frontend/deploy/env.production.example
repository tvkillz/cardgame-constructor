# Shared by all frontend sites on this VPS — API lives on the platform backend (e.g. voidborn.fun).
NEXT_PUBLIC_SUPABASE_URL=https://voidborn.fun
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy HS256 anon JWT — fallback if publishable key is unavailable
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Staging gate — HTTP basic auth (dev + prod pm2). Remove or set SITE_AUTH_DISABLED=1 before public launch.
SITE_AUTH_USERNAME=dev
SITE_AUTH_PASSWORD=dev
