# Copy to deploy.local.env (gitignored) and fill in your VPS details.

VPS_HOST=your-vps-hostname-or-ip
VPS_USER=root
VPS_FRONTEND_DIR=/root/constructor-files/frontend
VPS_PROJECTS_DIR=/root/constructor-files/projects

# pm2 app names to restart after deploy (comma-separated)
PM2_APPS=voidborn-prod,project2-prod

# Set to 1 to skip local build (artifact-only push)
# SKIP_BUILD=0
#
# CLI: --skip-game skips Vite play bundle (faster landing/portal deploys)

# Set to 1 to overwrite VPS .env.production from local file (usually leave 0)
# SYNC_ENV=0
