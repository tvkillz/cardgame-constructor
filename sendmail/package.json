{
  "name": "voidborn-sendmail",
  "version": "1.0.0",
  "private": true,
  "description": "cPanel mail relay — GoTrue send-email hook + authenticated SMTP API",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "generate-secrets": "node scripts/generate-secrets.mjs",
    "test:smtp": "node scripts/test-smtp.mjs",
    "test:api": "node scripts/test-api.mjs",
    "build:cpanel": "node scripts/build-cpanel.mjs",
    "deploy:cpanel": "node scripts/build-cpanel.mjs --upload"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nodemailer": "^6.9.16",
    "standardwebhooks": "^1.0.0"
  },
