# Copy to .env (gitignored). Also paste into cPanel Node.js → Environment Variables.

PORT=6001
NODE_ENV=production

# Path prefix on the Node app (must match nginx proxy — see README)
# Staging VPS (nginx strips /api/sendmail): leave empty
# cPanel Node app URL api/sendmail (no strip): /api/sendmail
BASE_PATH=

# cPanel / hosting mail server (StableServer). Do NOT use 127.0.0.1 unless Exim runs
# on the same VPS. mail.voidborn.fun A record must point at the mail host (209.42.18.27),
# not the frontend VPS — otherwise SMTP gets ECONNREFUSED.
SMTP_HOST=s13836.lon1.stableserver.net
SMTP_PORT=465
SMTP_USER=no-reply@voidborn.fun
SMTP_PASS=your-mailbox-password

SMTP_FROM_NAME=VOIDBORN
SMTP_ADMIN_EMAIL=no-reply@voidborn.fun
SMTP_SENDER_NAME=VOIDBORN

# Bearer token for POST /send, GET /smtp-health, POST /test
# Generate: npm run generate-secrets
MAIL_API_KEY=vb_mail_change_me

# GoTrue send-email hook (Standard Webhooks). Same value as GOTRUE_HOOK_SEND_EMAIL_SECRETS on API VPS.
# Generate: npm run generate-secrets
SEND_EMAIL_HOOK_SECRET=v1,whsec_change_me

# Where confirmation links point (your Supabase API host, not voidborn.fun)
AUTH_VERIFY_BASE_URL=https://api.voidborn.fun

# Frontend site — logo URL fallback when bundled asset is not found
SITE_URL=https://voidborn.fun
# Optional absolute logo URL (defaults to SITE_URL + /assets/brand/header.webp)
# MAIL_LOGO_URL=https://voidborn.fun/assets/brand/header.webp

# Default recipients for POST /test when body is empty
TEST_EMAIL_RECIPIENTS=andrewmalewski@gmail.com,tocytrus@inbox.lv

# Invoice seller block (mirrors projects/*/copy/footer.json contact)
INVOICE_COMPANY_NAME=Test LTD
INVOICE_COMPANY_NUMBER=00000000
INVOICE_COMPANY_ADDRESS=123 Example Street, Testville, TE1 1ST, United Kingdom
INVOICE_COMPANY_EMAIL=support@voidborn.fun
