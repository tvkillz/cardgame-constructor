# Copy to .env (gitignored). Same codebase on every frontend VPS — pick SMTP or Brevo via MAIL_TRANSPORT.

PORT=6001
NODE_ENV=production

# Path prefix on the Node app (must match nginx proxy — see README)
# nginx strips /api/sendmail → leave BASE_PATH empty
BASE_PATH=

# --- Transport (pick one per VPS) ---
# voidborn VPS:  MAIL_TRANSPORT=smtp
# komorebi VPS:  MAIL_TRANSPORT=brevo
MAIL_TRANSPORT=smtp

# --- SMTP mode (voidborn VPS) ---
SMTP_HOST=s13836.lon1.stableserver.net
SMTP_PORT=465
SMTP_USER=no-reply@voidborn.fun
SMTP_PASS=your-mailbox-password
SMTP_FROM_NAME=VOIDBORN
SMTP_ADMIN_EMAIL=no-reply@voidborn.fun
SMTP_SENDER_NAME=VOIDBORN

# --- Brevo mode (komorebi VPS — HTTPS API, no outbound SMTP ports) ---
# MAIL_TRANSPORT=brevo
# BREVO_API_KEY=xkeysib-...
# BREVO_SENDER_EMAIL=no-reply@komorebi.club
# BREVO_SENDER_NAME=KOMOREBI

# Bearer token for POST /send, GET /smtp-health, POST /test, POST /invoice
# Generate per VPS: npm run generate-secrets
MAIL_API_KEY=change_me_per_vps

# GoTrue send-email hook (Standard Webhooks). Must match API VPS SEND_EMAIL_HOOK_SECRET / GOTRUE_HOOK_SEND_EMAIL_SECRETS.
# Use the SAME hook secret on every sendmail instance (voidborn + komorebi).
# Generate once: npm run generate-secrets
SEND_EMAIL_HOOK_SECRET=v1,whsec_change_me

# Where confirmation links point (Supabase API host, not the public site)
AUTH_VERIFY_BASE_URL=https://api.voidborn.fun

# This VPS public site — logo URL fallback + branded templates
SITE_URL=https://voidborn.fun

# Optional per-site logo override (absolute URL)
# MAIL_LOGO_URL_IYASHIKEI=https://komorebi.club/assets/brand/header.webp

TEST_EMAIL_RECIPIENTS=you@example.com

# Invoice seller block (mirrors projects/{id}/copy/footer.json contact)
INVOICE_COMPANY_NAME=Test LTD
INVOICE_COMPANY_NUMBER=00000000
INVOICE_COMPANY_ADDRESS=123 Example Street, Testville, TE1 1ST, United Kingdom
INVOICE_COMPANY_EMAIL=support@voidborn.fun
